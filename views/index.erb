<!DOCTYPE html>
<html>
<head>
  <title>To-Do List</title>
</head>
<body>
  <h1>To-Do List</h1>

  <form action="/add" method="post">
    <input type="text" name="title" placeholder="Yeni görev...">
    <button type="submit">Ekle</button>
  </form>

  <ul>
    <% @todos.each do |todo| %>
      <li>
        <form action="/toggle/<%= todo[:id] %>" method="post" style="display:inline">
          <button type="submit"><%= todo[:completed] ? '✅' : '⬜' %></button>
        </form>
        <%= todo[:completed] ? '<s>' + todo[:title] + '</s>' : todo[:title] %>
        <form action="/delete/<%= todo[:id] %>" method="post" style="display:inline">
          <button type="submit">Sil</button>
        </form>
      </li>
    <% end %>
  </ul>

</body>
</html>